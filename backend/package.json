{
  "name": "bulkmail-backend",
  "version": "1.0.0",
  "description": "Backend API for BulkMail Pro - Email sending system",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "worker": "ts-node src/queue/emailWorker.ts",
    "test": "jest",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [
    "email",
    "bulkmail",
    "smtp",
    "queue"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "knex": "^3.1.0",
    "ioredis": "^5.3.2",
    "bull": "^4.12.0",
    "uuid": "^9.0.1",
    "yaml": "^2.3.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.5",
    "@types/bull": "^4.10.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
